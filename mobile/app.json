{
  "expo": {
    "name": "SeeForMe",
    "slug": "seefore",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#080B12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seefore.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SeeForMe uses the camera to detect obstacles and analyze scenes.",
        "NSMicrophoneUsageDescription": "SeeForMe uses the microphone to accept voice queries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080B12"
      },
      "package": "com.seefore.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-camera",
        {
          "cameraPermission": "SeeForMe uses the camera to detect obstacles.",
          "microphonePermission": "SeeForMe uses the microphone for voice queries."
        }
      ]
    ],
    "scheme": "seefore",
    "experiments": {
      "typedRoutes": true
    }
  }
}
