# Bootstrap URL — app fetches GET /api/public/config (URLs from MongoDB `app_config`, then env fallback).
# Never put MONGODB_URI in the app; only the API talks to Atlas.
EXPO_PUBLIC_BACKEND_URL=https://api.seefore.tech

# Live tab: YOLOv8 runs on-device (mobile/assets/models/yolov8n.tflite). Optional tuning:
# EXPO_PUBLIC_YOLO_CONF_THRESHOLD=0.25
# EXPO_PUBLIC_YOLO_CAUTION_AREA_FRACTION=0.25

# ── brain.py on your Mac (dev sync) ─────────────────────────────────────────
# Required for sync (do not use api.seefore.tech here). Run: backend/run_dev_sync.sh
# EXPO_PUBLIC_DEV_SYNC_URL=http://192.168.x.x:8000
# EXPO_PUBLIC_DEV_SYNC_SECRET=dev-local-secret
# Android USB: adb reverse tcp:8000 tcp:8000  →  http://127.0.0.1:8000
# After changing app.json (cleartext), use a dev build: npx expo run:ios | run:android
EXPO_PUBLIC_WS_URL=wss://api.seefore.tech
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your_auth0_client_id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://api.seefore.tech

# Google AI (required for Live / Ask). Use only ONE line — a duplicate empty key will clear it.
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional: ElevenLabs for Ask voice
EXPO_PUBLIC_ELEVENLABS_KEY=
EXPO_PUBLIC_ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM
