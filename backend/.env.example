# ── Option A: sync query.wav from phone → elsee/query.wav for brain.py ─────────
ENABLE_DEV_FILE_SYNC=1
DEV_SYNC_SECRET=dev-local-secret
CORS_ORIGINS=*

# Live tab — YOLOv8 (ultralytics): pip install ultralytics; first run downloads yolov8n.pt
# YOLO_MODEL_PATH=yolov8n.pt
# YOLO_CONF_THRESHOLD=0.25
# YOLO_CAUTION_AREA_FRACTION=0.06

# MongoDB — also stores `app_config` doc for GET /api/public/config (mobile URLs)
# MONGODB_URI=
# MONGODB_DB_NAME=seefore

# Fallbacks if `app_config` collection is empty (Atlas: insert doc _id "default")
# PUBLIC_API_BASE_URL=https://api.seefore.tech
# PUBLIC_WS_URL=wss://api.seefore.tech
# PUBLIC_DEV_SYNC_URL=

# SNOWFLAKE_ACCOUNT=
