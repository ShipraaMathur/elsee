# ── Option A: sync query.wav from phone → elsee/query.wav for brain.py ─────────
ENABLE_DEV_FILE_SYNC=1
DEV_SYNC_SECRET=dev-local-secret
CORS_ORIGINS=*

# MongoDB Atlas — same keys/defaults as test.py; STT → {MONGODB_DB_NAME}.test_collection
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/
# MONGODB_DB_NAME=seefore

# Fallbacks if `app_config` collection is empty (Atlas: insert doc _id "default")
# PUBLIC_API_BASE_URL=https://api.seefore.tech
# PUBLIC_WS_URL=wss://api.seefore.tech
# PUBLIC_DEV_SYNC_URL=

# Optional: require X-Transcript-Secret from mobile (EXPO_PUBLIC_TRANSCRIPT_LOG_SECRET)
# TRANSCRIPT_LOG_SECRET=

# SNOWFLAKE_ACCOUNT=
